# Binance API Keys
# Testnet keys: https://testnet.binancefuture.com/
# Mainnet keys: https://www.binance.com/en/my/settings/api-management
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Telegram Bot Integration
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal chat ID (get via @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Максимальний баланс для торгівлі (USDT).
# Бот не використає більше цієї суми, навіть якщо на акаунті більше.
# 0 = без обмеження (весь доступний баланс).
MAX_TRADING_BALANCE=1000

# Максимальна кількість одночасно відкритих позицій по всіх парах.
MAX_OPEN_TRADES_GLOBAL=3
